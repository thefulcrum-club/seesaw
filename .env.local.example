# URL of the seesaw-backend FastAPI service (thefulcrum-club/seesaw-backend).
# The frontend holds no Gemini/database credentials -- every request that
# needs those goes through this backend instead. Clone seesaw-backend as a
# sibling of this repo and run it locally (see its README) for this to work.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
