GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_WHISPER_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_KOKORO_SERVICE_URL=http://localhost:8880

# Optional: set these to use Vertex AI (GCP project billing/quota) instead of
# the plain Gemini API key. Requires `gcloud auth application-default login`
# locally. When GOOGLE_CLOUD_PROJECT is set, it takes priority over GEMINI_API_KEY.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
